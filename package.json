{
  "name": "evc-team-relay-selfhosted-monorepo",
  "private": true,
  "version": "1.1.7-wgwg.11",
  "description": "Canonical monorepo for the self-hosted EVC Team Relay plugin, control-plane, web publish, and relay server runtime.",
  "workspaces": [
    "apps/web-publish",
    "packages/*"
  ],
  "scripts": {
    "build:plugin": "npm --prefix apps/plugin run build",
    "sync:plugin-dist": "powershell -ExecutionPolicy Bypass -File deploy/sync-plugin-dist.ps1",
    "release:plugin": "npm --prefix apps/plugin run release",
    "beta:plugin": "npm --prefix apps/plugin run beta",
    "test:plugin": "npm --prefix apps/plugin run test",
    "lint:plugin": "npm --prefix apps/plugin run lint",
    "build:web": "npm --workspace apps/web-publish run build",
    "check:web": "npm --workspace apps/web-publish run check",
    "lint:web": "npm --workspace apps/web-publish run lint",
    "test:control-plane": "cd apps/control-plane && python -m pytest",
    "docker:build": "docker compose -f infra/docker-compose.yml build",
    "docker:config": "docker compose -f infra/docker-compose.yml config"
  },
  "devDependencies": {
    "svelte": "^5.55.1"
  },
  "dependencies": {
    "parse-diff": "^0.11.1"
  }
}
